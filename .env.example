# Gemini API Key - Lấy miễn phí tại https://aistudio.google.com/apikey
# Cách 1: Set trong .env (ưu tiên cao nhất)
MASTERAI_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Model settings
# MASTERAI_WHISPER_MODEL=base
# MASTERAI_LOG_LEVEL=INFO
# MASTERAI_PORT=7860
